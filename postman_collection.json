{
  "info": {
    "name": "Zorvyn FinTech Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@zorvyn.com\",\n  \"password\": \"StrongPass123!\"\n}"
        },
        "url": { "raw": "http://localhost:4000/auth/login", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["auth", "login"] }
      }
    },
    {
      "name": "Summary Total",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "http://localhost:4000/summary/total", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["summary", "total"] }
      }
    },
    {
      "name": "Create Record",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 2500,\n  \"type\": \"income\",\n  \"category\": \"salary\",\n  \"date\": \"2026-04-02\",\n  \"description\": \"Monthly salary\"\n}"
        },
        "url": { "raw": "http://localhost:4000/records", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["records"] }
      }
    }
  ],
  "variable": [
    { "key": "token", "value": "" }
  ]
}
