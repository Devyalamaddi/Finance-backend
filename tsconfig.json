{
	"compilerOptions": {
		"target": "ES2021",
		"module": "commonjs",
		"moduleResolution": "node",
		"rootDir": "./",
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0",
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "scripts/**/*.js"],
	"exclude": ["node_modules", "dist", "test"]
}
